// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x", "linux-arm64-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
}



model Local {
  id           String         @id @default(cuid())
  name         String
  address      String?
  phone        String?
  status       String         @default("Activo")
  professionals Professional[]
  resources     Resource[]
  appointments  Appointment[]
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
}

model Patient {
  id           String        @id @default(cuid())
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  name         String
  email        String?
  phone        String?
  identifier   String?       @unique // E.g., CURP
  status       String        @default("Activo") // Activo, Inactivo, Pendiente
  
  notifyEmail    Boolean     @default(true)
  notifyWhatsapp Boolean     @default(true)
  
  appointments   Appointment[]
  clinicalRecords ClinicalRecord[]
}

model Professional {
  id           String        @id @default(cuid())
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  name         String
  specialty    String?
  local        Local?        @relation(fields: [localId], references: [id])
  localId      String?
  appointments Appointment[]
  clinicalRecords ClinicalRecord[]
}

model Service {
  id           String        @id @default(cuid())
  name         String
  duration     Int           // in minutes
  price        Float?        @default(0)
  category     String?
  appointments Appointment[]
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
}

model Resource {
  id           String        @id @default(cuid())
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  name         String
  type         String        // Auditorio, Sala, Cabina, etc.
  local        Local?        @relation(fields: [localId], references: [id])
  localId      String?
  status       String        @default("Activo") // Activo, Mantenimiento
  services     String?       // Comma separated or JSON string
  appointments Appointment[]
}

model Appointment {
  id          String   @id @default(cuid())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  date        DateTime
  startTime   String   // HH:mm
  endTime     String?  // HH:mm
  type        String   // PROFESSIONAL, RESOURCE
  status      String   @default("PENDIENTE") // CONFIRMADA, PENDIENTE, ASISTIDA, CANCELADA
  notes       String?
  
  patient     Patient? @relation(fields: [patientId], references: [id])
  patientId   String?
  
  professional Professional? @relation(fields: [professionalId], references: [id])
  professionalId String?
  
  resource    Resource? @relation(fields: [resourceId], references: [id])
  resourceId  String?

  service     Service? @relation(fields: [serviceId], references: [id])
  serviceId   String?

  local       Local?   @relation(fields: [localId], references: [id])
  localId     String?
 
  reminderSent Boolean @default(false)
  recurrenceId String? // To group recurring instances
  notifications Notification[]
  clinicalRecord ClinicalRecord?
}

model Config {
  id    String @id @default(cuid())
  key   String @unique
  value String
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  name      String?
  role      String   @default("ADMIN") // ADMIN, USER
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Notification {
  id            String   @id @default(cuid())
  createdAt     DateTime @default(now())
  type          String   // WHATSAPP, EMAIL
  status        String   // SENT, FAILED, PENDING
  recipient     String   // Email or Phone number
  content       String?  @default("")
  error         String?
  
  appointmentId String?
  appointment   Appointment? @relation(fields: [appointmentId], references: [id])
}

model ClinicalRecord {
  id              String   @id @default(cuid())
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  date            DateTime @default(now())
  content         String   @db.Text
  diagnosis       String?  @db.Text
  treatment       String?  @db.Text
  
  patient         Patient  @relation(fields: [patientId], references: [id])
  patientId       String
  
  professional    Professional? @relation(fields: [professionalId], references: [id])
  professionalId  String?
  
  appointment     Appointment? @relation(fields: [appointmentId], references: [id])
  appointmentId   String?      @unique
  
  attachments     RecordAttachment[]
}
 
model RecordAttachment {
  id               String   @id @default(cuid())
  createdAt        DateTime @default(now())
  name             String
  url              String
  type             String
  size             Int
  
  clinicalRecord   ClinicalRecord @relation(fields: [clinicalRecordId], references: [id])
  clinicalRecordId String
}
